{
  "version": "1.0",
  "agents": [
    {
      "id": "task_classifier",
      "role": "planning",
      "input_keys": ["task_context"],
      "output_keys": ["classification_result"],
      "tools": ["text_editor"],
      "prompt_id": "task_classifier",
      "max_iterations": 5,
      "timeout_seconds": 120,
      "description": "Issue/MRの内容を分析してタスク種別を判定する"
    },
    {
      "id": "code_generation_planning",
      "role": "planning",
      "input_keys": [
        "task_context",
        "classification_result",
        "previous_plan_result",
        "replan_reason",
        "user_new_comments",
        "delta_requirements"
      ],
      "output_keys": ["plan_result", "todo_list", "plan_metadata"],
      "tools": ["text_editor", "create_todo_list"],
      "prompt_id": "code_generation_planning",
      "max_iterations": 15,
      "timeout_seconds": 300,
      "description": "コード生成タスクの実行計画を生成する",
      "metadata": {
        "todo_list_strategy": {
          "on_initial_plan": "create",
          "preserve_completed": true,
          "preserve_in_progress": true
        }
      }
    },
    {
      "id": "bug_fix_planning",
      "role": "planning",
      "input_keys": [
        "task_context",
        "classification_result",
        "previous_plan_result",
        "replan_reason",
        "user_new_comments",
        "delta_requirements"
      ],
      "output_keys": ["plan_result", "todo_list", "plan_metadata"],
      "tools": ["text_editor", "create_todo_list"],
      "prompt_id": "bug_fix_planning",
      "max_iterations": 15,
      "timeout_seconds": 300,
      "description": "バグ修正タスクの実行計画を生成する",
      "metadata": {
        "todo_list_strategy": {
          "on_initial_plan": "create",
          "preserve_completed": true,
          "preserve_in_progress": true
        }
      }
    },
    {
      "id": "test_creation_planning",
      "role": "planning",
      "input_keys": [
        "task_context",
        "classification_result",
        "previous_plan_result",
        "replan_reason",
        "user_new_comments",
        "delta_requirements"
      ],
      "output_keys": ["plan_result", "todo_list", "plan_metadata"],
      "tools": ["text_editor", "create_todo_list"],
      "prompt_id": "test_creation_planning",
      "max_iterations": 15,
      "timeout_seconds": 300,
      "description": "テスト作成タスクの実行計画を生成する",
      "metadata": {
        "todo_list_strategy": {
          "on_initial_plan": "create",
          "preserve_completed": true,
          "preserve_in_progress": true
        }
      }
    },
    {
      "id": "documentation_planning",
      "role": "planning",
      "input_keys": [
        "task_context",
        "classification_result",
        "previous_plan_result",
        "replan_reason",
        "user_new_comments",
        "delta_requirements"
      ],
      "output_keys": ["plan_result", "todo_list", "plan_metadata"],
      "tools": ["text_editor", "create_todo_list"],
      "prompt_id": "documentation_planning",
      "max_iterations": 15,
      "timeout_seconds": 300,
      "description": "ドキュメント生成タスクの実行計画を生成する",
      "metadata": {
        "todo_list_strategy": {
          "on_initial_plan": "create",
          "preserve_completed": true,
          "preserve_in_progress": true
        }
      }
    },
    {
      "id": "plan_reflection",
      "role": "reflection",
      "input_keys": [
        "plan_result",
        "todo_list",
        "task_context",
        "review_result",
        "user_new_comments",
        "execution_result"
      ],
      "output_keys": [
        "reflection_result",
        "replan_mode",
        "replan_reason",
        "delta_requirements",
        "affected_todos",
        "new_requirements",
        "conflicts",
        "comment_response"
      ],
      "tools": ["text_editor", "get_todo_list"],
      "prompt_id": "plan_reflection",
      "max_iterations": 10,
      "timeout_seconds": 180,
      "description": "プランを検証し、問題点と改善案を提示する。ユーザーコメントを解析して差分計画またはフル再計画を判定する"
    },
    {
      "id": "code_generation_fast",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_results"],
      "tools": [
        "text_editor",
        "command_executor",
        "update_todo_status"
      ],
      "prompt_id": "code_generation_fast",
      "max_iterations": 30,
      "timeout_seconds": 900,
      "description": "速度優先でコードを生成する。簡潔で動作する実装を最短ルートで完成させる"
    },
    {
      "id": "code_generation_standard",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_results"],
      "tools": [
        "text_editor",
        "command_executor",
        "update_todo_status"
      ],
      "prompt_id": "code_generation_standard",
      "max_iterations": 40,
      "timeout_seconds": 1800,
      "description": "品質と速度のバランスを取った標準的な実装でコードを生成する"
    },
    {
      "id": "code_generation_creative",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_results"],
      "tools": [
        "text_editor",
        "command_executor",
        "update_todo_status"
      ],
      "prompt_id": "code_generation_creative",
      "max_iterations": 40,
      "timeout_seconds": 1800,
      "description": "代替アプローチや創造的なデザインパターンを積極的に採用してコードを生成する"
    },
    {
      "id": "bug_fix",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_result"],
      "tools": [
        "text_editor",
        "command_executor",
        "update_todo_status"
      ],
      "prompt_id": "bug_fix",
      "max_iterations": 40,
      "timeout_seconds": 1800,
      "description": "バグ修正を実装する"
    },
    {
      "id": "test_creation",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_result"],
      "tools": [
        "text_editor",
        "command_executor",
        "update_todo_status"
      ],
      "prompt_id": "test_creation",
      "max_iterations": 30,
      "timeout_seconds": 1200,
      "description": "テストコードを作成する"
    },
    {
      "id": "documentation",
      "role": "execution",
      "input_keys": ["plan_result", "task_context"],
      "output_keys": ["execution_result"],
      "tools": ["text_editor", "update_todo_status"],
      "prompt_id": "documentation",
      "max_iterations": 30,
      "timeout_seconds": 900,
      "description": "ドキュメントを作成する"
    },
    {
      "id": "code_review",
      "role": "review",
      "input_keys": ["branch_envs", "execution_results", "task_context"],
      "output_keys": ["review_result", "selected_implementation"],
      "tools": ["text_editor"],
      "prompt_id": "code_review_multi",
      "max_iterations": 15,
      "timeout_seconds": 600,
      "description": "コード生成タスクでは3つの並列実装を比較し最良の実装を自動選択する。バグ修正・テスト作成タスクでは標準的なコードレビューを実施する"
    },
    {
      "id": "documentation_review",
      "role": "review",
      "input_keys": ["execution_result", "task_context"],
      "output_keys": ["review_result"],
      "tools": ["text_editor"],
      "prompt_id": "documentation_review",
      "max_iterations": 10,
      "timeout_seconds": 300,
      "description": "ドキュメントレビューを実施する"
    },
    {
      "id": "test_execution_evaluation",
      "role": "review",
      "input_keys": ["execution_result", "task_context"],
      "output_keys": ["review_result"],
      "tools": ["command_executor"],
      "prompt_id": "test_execution_evaluation",
      "max_iterations": 15,
      "timeout_seconds": 600,
      "description": "テストを実行し結果を評価する"
    },
    {
      "id": "code_generation_reflection",
      "role": "reflection",
      "input_keys": [
        "execution_result",
        "plan_result",
        "task_context",
        "todo_list"
      ],
      "output_keys": ["execution_reflection_result"],
      "tools": ["text_editor", "get_todo_list"],
      "prompt_id": "code_generation_reflection",
      "max_iterations": 10,
      "timeout_seconds": 300,
      "description": "バグ修正の成果物を検証し、品質・仕様準拠・再実装判定を行う"
    },
    {
      "id": "test_creation_reflection",
      "role": "reflection",
      "input_keys": [
        "execution_result",
        "plan_result",
        "task_context",
        "todo_list"
      ],
      "output_keys": ["execution_reflection_result"],
      "tools": ["text_editor", "get_todo_list"],
      "prompt_id": "test_creation_reflection",
      "max_iterations": 10,
      "timeout_seconds": 300,
      "description": "テスト作成の成果物を検証し、テストカバレッジ・品質・再実装判定を行う"
    },
    {
      "id": "documentation_reflection",
      "role": "reflection",
      "input_keys": [
        "execution_result",
        "plan_result",
        "task_context",
        "todo_list"
      ],
      "output_keys": ["execution_reflection_result"],
      "tools": ["text_editor", "get_todo_list"],
      "prompt_id": "documentation_reflection",
      "max_iterations": 10,
      "timeout_seconds": 300,
      "description": "ドキュメント作成の成果物を検証し、正確性・完全性・再実装判定を行う"
    }
  ]
}
