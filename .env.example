# ========================================
# AutomataCodex 環境変数設定
# cp .env.example .env してから値を設定してください
# セットアップ手順は SETUP.md を参照してください
# ========================================

# GitLab bot用 Personal Access Token（必須）
GITLAB_PAT=your-gitlab-pat-here

# GitLab インスタンスURL（セルフホスト版を使う場合のみ設定。デフォルト: https://gitlab.com）
# GITLAB_URL=http://your-gitlab-host

# PostgreSQL パスワード（必須）
POSTGRES_PASSWORD=your-postgres-password-here

# RabbitMQ パスワード（必須）
RABBITMQ_PASS=your-rabbitmq-password-here

# APIキー暗号化用ランダムキー（必須・32バイト以上）
# 生成コマンド: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-encryption-key-here

# JWT署名キー（必須）
JWT_SECRET_KEY=your-jwt-secret-here

# Consumer → Backend JWT認証用サービスアカウント（必須）
# SETUP.md 手順3で作成する管理者ユーザーのユーザー名・パスワードと一致させること
USER_CONFIG_API_SERVICE_USERNAME=your-admin-username
USER_CONFIG_API_SERVICE_PASSWORD=your-admin-password
