# ========================================
# AutomataCodex 環境変数設定サンプル
# このファイルを .env にコピーして値を設定してください
# ========================================

# GitLab設定（必須）
# botアカウント用Personal Access Token
GITLAB_PAT=your-gitlab-pat-here
# GitLab APIのベースURL（デフォルト: https://gitlab.com）
GITLAB_URL=https://gitlab.com

# PostgreSQL設定（必須）
# データベース接続パスワード
POSTGRES_PASSWORD=your-postgres-password-here

# RabbitMQ設定（必須）
# RabbitMQのユーザー名（デフォルト: agent）
RABBITMQ_USER=agent
# RabbitMQのパスワード
RABBITMQ_PASS=your-rabbitmq-password-here
# RabbitMQ接続URL（任意。設定時はRABBITMQ_HOST/USER/PASSより優先）
# RABBITMQ_URL=amqp://agent:your-rabbitmq-password-here@rabbitmq:5672/

# 暗号化設定（必須）
# APIキー暗号化用の32バイト以上のランダムキー
# 生成コマンド例: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-encryption-key-here

# JWT設定（必須: User Config API認証用）
JWT_SECRET=your-jwt-secret-here

# OpenAI設定（フォールバック用）
# User Config APIに未登録ユーザー向けのデフォルトAPIキー
OPENAI_API_KEY=your-openai-api-key-here

# User Config API認証キー
USER_CONFIG_API_KEY=your-user-config-api-key-here

# OpenTelemetry設定（任意）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ========================================
# 試験用 GitLab 設定（--profile testing 使用時のみ有効）
# 起動コマンド: docker-compose --profile testing up gitlab
# ========================================
# 試験用 GitLab HTTP ポート（デフォルト: 8929）
GITLAB_TEST_PORT=8929
# 試験用 GitLab SSH ポート（デフォルト: 2289）
GITLAB_TEST_SSH_PORT=2289
# GitLab URL を試験用 GitLab に向ける場合は下記を有効化
# GITLAB_URL=http://localhost:8929
